# WeaselOMeter configuration — copy to .env and fill in.
# .env is git-ignored; .env.example is the tracked template.

# Flask session secret (any long random string)
SECRET_KEY=change-me-to-a-long-random-string

# ── Cloudflare Access (same pattern as ARMR) ─────────────────────────────────
# Leave CF_TEAM_DOMAIN blank for local dev (writes are then allowed without auth).
# In production set both; the app verifies the Cf-Access-Jwt-Assertion JWT.
CF_TEAM_DOMAIN=
CF_AUD=

# ── Who may edit the word bank ───────────────────────────────────────────────
# Comma-separated emails allowed to POST changes. Falls back to ADMIN_EMAILS.
# If both are empty AND Cloudflare Access is enabled, any authenticated CF user
# may edit. If Cloudflare Access is disabled (local), editing is open.
EDITOR_EMAILS=
ADMIN_EMAILS=
