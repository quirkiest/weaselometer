    },
    {
      "max": 50,
      "label": "Heavy Weaselage",
      "blurb": "This document needs a shower and a plain-English coach."
    },
    {
      "max": 100,
      "label": "OMG TOTAL WEASEL",
      "blurb": "Pure, distilled gobbledygook. The Golden Bull salutes you."
    }
  ],
